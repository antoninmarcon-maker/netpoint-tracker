# =============================================================================
# My Volley - Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Lines prefixed with VITE_ are exposed to the browser bundle.

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Used by edge functions and server-side scripts (never exposed to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Push Notifications (VAPID keys)
# -----------------------------------------------------------------------------
# Browser-side public key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Server-side keys (used by edge functions send-tutorial-push, send-friday-push)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# -----------------------------------------------------------------------------
# Google / Gemini (used by edge functions and enrichment scripts)
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# Social Media Marketing (optional, used by scripts/marketing/)
# -----------------------------------------------------------------------------
META_ACCESS_TOKEN=your-meta-access-token
META_PAGE_ID=your-meta-page-id
META_IG_USER_ID=your-meta-instagram-user-id
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
